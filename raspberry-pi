        def start_lockout(seconds: int):
            """
            Start a temporary lockout:
            - disables keypad
            - updates countdown every 200ms
            - displays "LOCKED Ns" in the pin bar
            """
            self.pin_locked_until = time.time() + seconds
            set_keypad_enabled(False)

            def tick():
                rem = int(self.pin_locked_until - time.time())
                if rem <= 0:
                    # lockout over -> restore UI
                    self.pin_lock_var.set("")
                    self.pin_var.set("")
                    try:
                        self._pinbox.config(highlightbackground=BORDER)
                        self._pin_display_label.config(fg=WHITE_TXT)
                    except Exception:
                        pass
                    set_keypad_enabled(True)
                    return

                # lockout replaces the PIN bar text
                self.pin_var.set(f"LOCKED {rem}s")
                self.pin_lock_var.set(f"LOCKOUT: {rem}s")
                try:
                    self._pinbox.config(highlightbackground=NEON_RED)
                    self._pin_display_label.config(fg=NEON_RED)
                except Exception:
                    pass

                self.root.after(200, tick)

            tick()

        def add_digit(d):
            """Append a digit to the PIN entry (masked bullets)."""
            if locked_now():
                return
            if len(self.pin_entered) >= 10:  # guard against super long pin
