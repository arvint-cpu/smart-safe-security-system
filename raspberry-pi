    # PIN MELTDOWN (4 wrong attempts)
    def pin_meltdown(self):
        """
        Triggered when PIN_MAX_ATTEMPTS reached.
        - siren
        - lots of popups
        - hard exit using os._exit (force-kill)
        """
        self.log_event("*** PIN MELTDOWN TRIGGERED (4 wrong attempts) ***")
        try:
            arduino_send("SIREN")
        except Exception:
            pass

        positions = scattered_positions(self.root, 18)
        for i, (x, y) in enumerate(positions, start=1):
            popup_at("ACCESS DENIED", f"PIN FAILURE\n\nATTEMPTS EXCEEDED\n\nPOPUP {i}/18", x, y, NEON_RED, "white", ms=850)
            self.root.update_idletasks()
            time.sleep(0.04)

        self.root.after(200, lambda: os._exit(0))

    # KEYPAD / PIN screen
    def build_keypad(self):
        """
        Builds the PIN entry UI:
        - masked PIN display
        - keypad buttons
        - lockout countdown after PIN_LOCKOUT_AFTER
        - melts down after PIN_MAX_ATTEMPTS
        """
        self.clear()
        self.build_topbar("AUTHENTICATION")
        wrap = self.make_bg_body()

        shell = tk.Frame(wrap, bg=CARD, highlightbackground=BORDER, highlightthickness=3)
        shell.grid(row=0, column=0, sticky="nsew")

        shell.grid_columnconfigure(0, weight=3, uniform="cols")
        shell.grid_columnconfigure(1, weight=2, uniform="cols")
        shell.grid_rowconfigure(0, weight=0)
        shell.grid_rowconfigure(1, weight=1)

