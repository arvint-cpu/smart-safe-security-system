        def submit_pin():
            """Validate pin, manage attempts + lockout + meltdown."""
            if locked_now():
                return

            # Correct PIN -> proceed to keycard scan screen
            if self.pin_entered == PIN_CODE:
                self.log_event("PIN accepted")
                self.pin_msg.set("ACCESS GRANTED")
                try:
                    self._pinbox.config(highlightbackground=BORDER)
                    self._pin_display_label.config(fg=WHITE_TXT)
                except Exception:
                    pass
                self.root.after(250, self.build_keycard)
                return

            # Wrong PIN path
            self.pin_attempts += 1
            self.log_event(f"PIN denied (attempt {self.pin_attempts}/{PIN_MAX_ATTEMPTS})")
            self.pin_msg.set(f"WRONG CODE ({self.pin_attempts}/{PIN_MAX_ATTEMPTS})")

            # Make Arduino beep if available
            try:
                arduino_send("BEEP")
            except Exception:
                pass

            wrong_pin_feedback()

            # Lockout after PIN_LOCKOUT_AFTER
            if self.pin_attempts == PIN_LOCKOUT_AFTER:
                self.log_event(f"PIN lockout {PIN_LOCKOUT_SECONDS}s")
                start_lockout(PIN_LOCKOUT_SECONDS)
                return

            # Meltdown after max attempts
            if self.pin_attempts >= PIN_MAX_ATTEMPTS:
                self.pin_meltdown()
                return

