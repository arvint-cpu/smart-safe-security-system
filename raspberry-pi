PIN_LOCKOUT_SECONDS = 15      # lockout duration in seconds

SCAN_SETTLE_SECONDS = 3       # wait time before requesting Arduino COLOR?
UNKNOWN_TRIGGER_COUNT = 2     # how many UNKNOWN reads before meltdown
LOG_FILE = "color_ui_log.txt" # appended event log file

EDGE_PAD = 26  # always show a border of the moving background (UI aesthetic padding)


# SERIAL CONFIG
BAUD = 9600
TIMEOUT = 3.0
AUTO_PORTS = ["/dev/ttyUSB0", "/dev/ttyACM0", "/dev/ttyUSB1", "/dev/ttyACM1"]

# THEME COLORS (UI palette)
BG = "#070A14"
