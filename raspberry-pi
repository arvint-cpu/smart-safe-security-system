#!/usr/bin/env python3
"""
SECURE COLOR VERIFICATION (Pi UI)

What this does:
- Fullscreen Tkinter UI with animated neon background.
- Stage 1: PIN keypad (max attempts + lockout).
- Stage 2: Keycard scan button triggers Arduino COLOR? read.
- Arduino responses drive actions: GREEN unlock, RED lock, BLUE police flash+siren, WHITE hard shutdown, UNKNOWN counted then meltdown.
- Logs everything to a text file + in-app event log.

Important threading rule:
- Tkinter UI must not be blocked; long waits happen in background threads,
  and UI updates are done using root.after(...) when needed.
"""

import tkinter as tk
from tkinter import ttk
import time, sys, random, threading, os
from datetime import datetime
 
# SETTINGS (core behavior)
PIN_CODE = "6769420"          # correct PIN
PIN_MAX_ATTEMPTS = 4          # total allowed PIN failures before meltdown
