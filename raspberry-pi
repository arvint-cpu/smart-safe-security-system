        self.container = tk.Frame(self.root, bg=BG)
        self.container.pack(fill="both", expand=True)

        # initial screen
        self.build_home()
        self.log_event("UI booted")

        # start serial status polling shortly after boot
        self.root.after(80, self.refresh_serial_status)

    # background wrapper 
    def make_bg_body(self):
        """
        Creates the animated background canvas and a padded wrapper
        where main cards get placed.
        """
        self.container.grid_rowconfigure(0, weight=0)
        self.container.grid_rowconfigure(1, weight=1)
        self.container.grid_columnconfigure(0, weight=1)

        body = tk.Frame(self.container, bg=BG)
        body.grid(row=1, column=0, sticky="nsew")

        bg = NeonBackground(body)
        bg.place(x=0, y=0, relwidth=1, relheight=1)

        # wrapper inset so background is visible around edges
        wrapper = tk.Frame(body, bg=BG)
        wrapper.place(
            x=EDGE_PAD, y=EDGE_PAD,
            relwidth=1, relheight=1,
            width=-2 * EDGE_PAD, height=-2 * EDGE_PAD
        )
        wrapper.grid_rowconfigure(0, weight=1)
        wrapper.grid_columnconfigure(0, weight=1)
        return wrapper

    # UI effects (shake + glow pulse) 
    def shake_root(self, duration_ms=520, intensity=10, interval=22):
        """
        Shake the whole window by jittering its X/Y position.
        (Works best when not in true fullscreen on some window managers.)
        """
        try:
            self.root.update_idletasks()
            base = self.root.geometry()  # "WxH+X+Y"
            parts = base.split("+")
            if len(parts) < 3:
                return
            wh = parts[0]
            base_x = int(parts[1])
            base_y = int(parts[2])
        except Exception:
            return

        start = time.time()

        def tick():
            # stop after duration
            if (time.time() - start) * 1000 >= duration_ms:
                self.root.geometry(f"{wh}+{base_x}+{base_y}")
                return
            dx = random.randint(-intensity, intensity)
            dy = random.randint(-intensity, intensity)
            self.root.geometry(f"{wh}+{base_x + dx}+{base_y + dy}")
            self.root.after(interval, tick)

        tick()

    def pulse_pinbox_red(self, pulses=6, interval=80):
        """
        Flash the PIN box border and PIN text red for quick wrong-PIN feedback.
        """
        if not self._pinbox or not self._pin_display_label:
            return

        state = {"on": False, "i": 0}
        orig_border = BORDER
        orig_fg = WHITE_TXT

        def tick():
            if not self._pinbox or not self._pin_display_label:
                return

            # finished all pulses -> restore colors
            if state["i"] >= pulses:
                try:
                    self._pinbox.config(highlightbackground=orig_border)
                    self._pin_display_label.config(fg=orig_fg)
                except Exception:
                    pass
                return

            state["on"] = not state["on"]
            try:
                self._pinbox.config(highlightbackground=(NEON_RED if state["on"] else orig_border))
                self._pin_display_label.config(fg=(NEON_RED if state["on"] else orig_fg))
            except Exception:
                pass

            state["i"] += 1
            self.root.after(interval, tick)

        tick()

    # logging 
    def log_event(self, msg):
        """
        Log to:
        - in-memory buffer (for UI log viewer)
        - LOG_FILE on disk (append)
        - on-screen log widget if currently present
        """
        ts = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        line = f"[{ts}] {msg}"
        self.log_buffer.append(line)

        try:
            with open(LOG_FILE, "a") as f:
                f.write(line + "\n")
        except Exception:
            pass

        if self.log_text is not None and self.log_text.winfo_exists():
            self.log_text.configure(state="normal")
            self.log_text.insert("end", line + "\n")
            self.log_text.see("end")
            self.log_text.configure(state="disabled")

    # serial
    def refresh_serial_status(self):
        """
        Try to connect to Arduino and update the status label.
        If it fails, retry every ~900ms.
        """
        ok, msg = serial_autoconnect()
        self.serial_status = f"Serial: {'OK' if ok else 'FAIL'} — {msg}"
        try:
            self.status_lbl.config(text=self.serial_status)
            self.serial_var.set(self.serial_status)
        except Exception:
            pass

        if ok:
            self.log_event(self.serial_status)
        else:
            self.root.after(900, self.refresh_serial_status)

    # lifecycle 
    def clear(self):
        """Destroy all current UI in the container before building next screen."""
        for w in self.container.winfo_children():
            w.destroy()
        self.log_text = None
        self._pinbox = None
        self._pin_display_label = None

    def exit_program(self):
        """
        Exit handler:
        - send LOCK to Arduino (servo safe position)
        - close serial
        - destroy Tk root
        - sys.exit
        """
        self.log_event("EXIT -> locking servo then quitting")
        try:
            arduino_send("LOCK")
        except Exception:
            pass
        serial_disconnect()

        try:
            self.root.destroy()
        finally:
            sys.exit(0)

    def set_state(self, state):
        """Update the state label color + text."""
        self.lock_state = state
        try:
            self.state_lbl.config(
                text=f"STATE: {state}",
                fg=NEON_GREEN if state == "UNLOCKED" else NEON_RED
            )
        except Exception:
            pass

    def do_lock(self, why=""):
        """Lock action: log, send LOCK to Arduino, update UI state."""
        self.log_event(f"LOCK ({why})")
        arduino_send("LOCK")
        self.set_state("LOCKED")

    def do_unlock(self, why=""):
        """Unlock action: log, send UNLOCK to Arduino, update UI state."""
        self.log_event(f"UNLOCK ({why})")
        arduino_send("UNLOCK")
        self.set_state("UNLOCKED")

    # topbar 
    def build_topbar(self, title):
        """
        The top panel shown on every screen:
        - title
        - state (LOCKED/UNLOCKED)
        - serial status
        """
        top = tk.Frame(self.container, bg=PANEL)
        top.grid(row=0, column=0, sticky="ew")
        top.grid_columnconfigure(0, weight=1)

        tk.Label(
            top, text=title, bg=PANEL, fg=WHITE_TXT,
            font=("Arial", 14, "bold")
        ).grid(row=0, column=0, padx=14, pady=(10, 0), sticky="w")

        self.state_lbl = tk.Label(
            top, text=f"STATE: {self.lock_state}",
            bg=PANEL, fg=NEON_RED, font=("Arial", 11, "bold")
        )
        self.state_lbl.grid(row=0, column=1, padx=14, pady=(10, 0), sticky="e")

        self.status_lbl = tk.Label(
            top, text=self.serial_status, bg=PANEL,
            fg=MUTED, font=("Arial", 10, "bold")
        )
        self.status_lbl.grid(row=1, column=0, columnspan=2, padx=14, pady=(0, 10), sticky="w")

