ser = None
PORT_IN_USE = None

# Try importing pyserial; if missing, app still runs but scanning will fail.
try:
    import serial
    SERIAL_OK = True
except Exception:
    SERIAL_OK = False


def serial_disconnect():
    """Close serial connection cleanly (if open)."""
    global ser, PORT_IN_USE
    try:
        if ser and ser.is_open:
            ser.close()
    except Exception:
        pass
    ser = None
    PORT_IN_USE = None


def serial_autoconnect():
    """
    Attempt to auto-connect to Arduino over common Linux serial ports.

    Returns:
      (True, "OK (...)") on success
      (False, "error message") on failure
    """
    global ser, PORT_IN_USE
    if not SERIAL_OK:
        return False, "pyserial not installed (sudo apt install -y python3-serial)"

    # If already open, reuse it.
    if ser and getattr(ser, "is_open", False):
        return True, f"OK ({PORT_IN_USE})"

    last_err = None
    for p in AUTO_PORTS:
        try:
            ser = serial.Serial(p, BAUD, timeout=TIMEOUT)
            PORT_IN_USE = p
            time.sleep(1.4)  # Arduino resets when serial opens; wait for it to boot
            return True, f"OK ({p})"
        except Exception as e:
            last_err = e
            ser = None
            PORT_IN_USE = None

    return False, f"Auto-connect failed. Tried {AUTO_PORTS}. Last error: {last_err}"


def arduino_send(cmd: str):
    """
    Send a command to Arduino (LOCK/UNLOCK/SIREN/BEEP/etc).
    Tries to read a short acknowledgement line:
      OK:...
      ERR:...
    If none seen, returns ("SENT") as best-effort.
    """
    ok, msg = serial_autoconnect()
    if not ok:
        return False, msg

    try:
        # Clear stale input so we don't read old lines.
        try:
            ser.reset_input_buffer()
        except Exception:
            pass

        ser.write((cmd.strip().upper() + "\n").encode())
        ser.flush()

        # Read a few lines for a structured response.
        for _ in range(10):
            line = ser.readline().decode(errors="ignore").strip()
            if not line:
                continue
            if line.startswith("OK:") or line.startswith("ERR:"):
                return line.startswith("OK:"), line

        return True, "SENT"
    except Exception as e:
        return False, f"Serial error: {e}"


def arduino_request_color():
    """
    Ask Arduino for a color classification.
    Expected Arduino response format:
      COLOR:GREEN / COLOR:RED / COLOR:BLUE / COLOR:WHITE / COLOR:UNKNOWN

    Returns:
      (color_string, None) on success
      (None, error_message) on failure
    """
    ok, msg = serial_autoconnect()
    if not ok:
        return None, msg

    try:
        try:
            ser.reset_input_buffer()
        except Exception:
            pass

        ser.write(b"COLOR?\n")
        ser.flush()

        # Try multiple reads (Arduino may take a moment).
        for _ in range(30):
            line = ser.readline().decode(errors="ignore").strip()
            if not line:
                continue
            if line.startswith("COLOR:"):
                return line.split(":", 1)[1].strip().upper(), None

        return None, "No COLOR response"
    except Exception as e:
        return None, f"Serial error: {e}"


# POPUPS / FLASH (visual alerts)
def scattered_positions(root, count):
    """
    Generate random screen positions for multiple popups (scattered effect).
    """
    root.update_idletasks()
    sw = root.winfo_screenwidth()
    sh = root.winfo_screenheight()
    min_x, max_x = 10, max(10, sw - POP_W - 10)
    min_y, max_y = 10, max(10, sh - POP_H - 10)
    return [(random.randint(min_x, max_x), random.randint(min_y, max_y)) for _ in range(count)]


def popup_at(title, text, x, y, bg, fg, ms=500):
    """
    Create a temporary topmost popup window at (x,y), auto-destroy after ms.
    """
    w = tk.Toplevel()
    w.title(title)
    w.attributes("-topmost", True)
    w.geometry(f"{POP_W}x{POP_H}+{x}+{y}")
    w.configure(bg=bg)

    lbl = tk.Label(
        w, text=text, bg=bg, fg=fg,
        font=("Arial", 13, "bold"),
        justify="center", wraplength=POP_W - 20
    )
    lbl.pack(expand=True, fill="both", padx=10, pady=10)

    w.after(ms, w.destroy)
    return w


def police_flash_sequence(root, cycles=26, speed_ms=105):
    """
    Flash alternating red/blue popups in the center (police light vibe).
    Runs in a daemon thread to avoid freezing UI.
    """
    def run():
        root.update_idletasks()
        cx = (root.winfo_screenwidth() - POP_W) // 2
        cy = (root.winfo_screenheight() - POP_H) // 2
        for _ in range(cycles):
            # Use root.after to create popups from the Tk thread.
            root.after(0, lambda: popup_at("🚔 WARNING", "POLICE MODE", cx, cy, NEON_RED, "white", ms=speed_ms))
            time.sleep(speed_ms / 1000.0)
            root.after(0, lambda: popup_at("🚔 WARNING", "POLICE MODE", cx, cy, NEON_BLUE, "black", ms=speed_ms))
            time.sleep(speed_ms / 1000.0)

    threading.Thread(target=run, daemon=True).start()


# BACKGROUND (animated neon)
class NeonBackground(tk.Canvas):
    """
    Animated canvas:
    - Moving neon "blobs" (large rings)
    - Floating particles (small dots)
    Renders every ~16ms (~60fps).
    """
    def __init__(self, parent):
        parent.update_idletasks()
        self.w = max(10, parent.winfo_width())
        self.h = max(10, parent.winfo_height())
        super().__init__(parent, width=self.w, height=self.h, bg=BG, highlightthickness=0)

        self.particles = []
        self.blobs = []
        self._init_scene()
        self.after(16, self._tick)

    def _init_scene(self):
        """Initialize blob positions and particle field."""
        self.blobs = [
            {"x": 0.20 * self.w, "y": 0.22 * self.h, "r": 0.46 * self.h, "dx": 0.22,  "dy": 0.16,  "c": NEON_PURPLE},
            {"x": 0.82 * self.w, "y": 0.18 * self.h, "r": 0.42 * self.h, "dx": -0.20, "dy": 0.18,  "c": NEON_CYAN},
            {"x": 0.84 * self.w, "y": 0.80 * self.h, "r": 0.52 * self.h, "dx": -0.16, "dy": -0.14, "c": NEON_BLUE},
        ]

        for _ in range(75):
            self.particles.append({
                "x": random.uniform(0, self.w),
                "y": random.uniform(0, self.h),
                "vx": random.uniform(-0.35, 0.35),
                "vy": random.uniform(-0.35, 0.35),
                "r": random.uniform(1.2, 2.6),
                "c": random.choice([NEON_CYAN, NEON_BLUE, NEON_PURPLE, "#FFFFFF"])
            })

    def _tick(self):
        """Render one frame: update positions, then redraw everything."""
        self.delete("all")

        # Draw moving blobs (concentric rings)
        for b in self.blobs:
            b["x"] += b["dx"]
            b["y"] += b["dy"]

            # bounce off screen with margin
            if b["x"] < -80 or b["x"] > self.w + 80:
                b["dx"] *= -1
            if b["y"] < -80 or b["y"] > self.h + 80:
                b["dy"] *= -1

            x, y, r, c = b["x"], b["y"], b["r"], b["c"]
            for k in range(5):
                rr = r - k * 0.055 * self.h
                if rr <= 0:
                    continue
                self.create_oval(x - rr, y - rr, x + rr, y + rr, outline=c, width=max(1, 5 - k))

        # Draw particles (small filled circles)
        for p in self.particles:
            p["x"] += p["vx"]
            p["y"] += p["vy"]
            if p["x"] < 0 or p["x"] > self.w:
                p["vx"] *= -1
            if p["y"] < 0 or p["y"] > self.h:
                p["vy"] *= -1

            x, y, r = p["x"], p["y"], p["r"]
            self.create_oval(x - r, y - r, x + r, y + r, outline="", fill=p["c"])

        self.after(16, self._tick)


# BUTTON (glow frame wrapper)
def glow_button(parent, text, command, accent=NEON_CYAN, font_size=14):
    """
    Creates a "glow" style by nesting a colored outer frame around a dark button.
    Returns:
      (outer_frame, button_widget)
    """
    outer = tk.Frame(parent, bg=accent)
    inner = tk.Frame(outer, bg=BG)

    btn = tk.Button(
        inner, text=text, command=command,
        font=("Arial", font_size, "bold"),
        bg=BTN_DARK, fg=WHITE_TXT,
        activebackground=BTN_DARK_HI, activeforeground=WHITE_TXT,
        relief="flat", bd=0,
        padx=14, pady=10,
        cursor="hand2"
    )
    inner.pack(padx=2, pady=2)
    btn.pack(fill="x")
    return outer, btn



# APP (main UI + logic)
class App:
    def __init__(self, root):
        # ---- root window configuration ----
