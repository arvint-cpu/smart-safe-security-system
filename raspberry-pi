        self.root.title("SECURE COLOR VERIFICATION")
        self.root.configure(bg=BG)
        self.root.resizable(False, False)

        # Fullscreen kiosk mode; Escape exits (for dev/testing).
        self.root.attributes("-fullscreen", True)
        self.root.bind("<Escape>", lambda e: self.exit_program())
        self.root.protocol("WM_DELETE_WINDOW", self.exit_program)

        # runtime state
        self.serial_status = "Serial: connecting…"
        self.lock_state = "LOCKED"

        # Persisted log lines (for showing in UI later).
        self.log_buffer = []
        self.log_text = None

        # PIN UI state
        self.pin_entered = ""
        self.pin_var = tk.StringVar(value="")      # shows masked pin or lockout text
        self.pin_msg = tk.StringVar(value="")      # feedback like "wrong code"
        self.pin_lock_var = tk.StringVar(value="") # lockout countdown text

        self.pin_attempts = 0
        self.pin_locked_until = 0.0
        self.pin_key_buttons = []
        self.pin_enter_btn = None

        # references for shake/pulse effects
        self._pinbox = None
        self._pin_display_label = None

        # scan logic state
        self.unknown_count = 0
        self.scanning = False

        # ttk style
        style = ttk.Style()
        try:
            style.theme_use("clam")
        except Exception:
