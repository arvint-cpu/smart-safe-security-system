    # SCAN FLOW (threaded)
    def start_scan(self):
        """
        Start one scan:
        - ensure serial ready
        - disable button while scanning
        - show settle progress (in a thread)
        - request Arduino COLOR?
        - return result to UI via root.after
        """
        if self.scanning:
            return

        ok, msg = serial_autoconnect()
        if not ok:
            self.log_event(f"Cannot scan: {msg}")
            self.scan_status_var.set("Serial not ready.")
            return

        self.scanning = True
        self.btn_scan.config(state="disabled")
        self.scan_status_var.set(f"Stabilizing… {SCAN_SETTLE_SECONDS}s")
        self.bar["value"] = 0

        def run():
            # settle countdown (progress bar)
            total = SCAN_SETTLE_SECONDS * 100
            for i in range(total + 1):
                self.bar["value"] = (i / total) * 100
                time.sleep(0.01)

            # UI updates must happen in Tk thread:
            self.root.after(0, lambda: self.scan_status_var.set("Reading…"))
            self.log_event("Requesting COLOR? from Arduino")

            # Serial request
            val, err = arduino_request_color()

            # handle result on UI thread
            self.root.after(0, lambda: self.handle_color(val, err))

        threading.Thread(target=run, daemon=True).start()

    def _reenable_scan(self):
        """Reset scan state and re-enable scan button."""
        self.scanning = False
        try:
            self.btn_scan.config(state="normal")
        except Exception:
            pass
        try:
            self.bar["value"] = 0
        except Exception:
            pass

    def meltdown(self, reason):
        """
        General meltdown:
        - log
        - siren
        - popups
        - hard exit
        """
        self.log_event(f"*** MELTDOWN TRIGGERED: {reason} ***")
        arduino_send("SIREN")

        positions = scattered_positions(self.root, 16)
        for i, (x, y) in enumerate(positions, start=1):
            popup_at("SYSTEM ALERT", f"{reason}\n\nPOPUP {i}/16", x, y, NEON_RED, "white", ms=900)
            self.root.update_idletasks()
            time.sleep(0.045)

        self.root.after(200, lambda: os._exit(0))

    def handle_color(self, val, err):
        """
        Interpret Arduino color result and trigger system actions.
        """
        self._reenable_scan()

        # If serial request failed
        if err:
            self.log_event(f"Scan error: {err}")
            self.last_color_var.set("Last read: (error)")
            self.big_color_var.set("ERROR")
            self.big_color_lbl.config(bg=CARD2, fg=NEON_RED)
            self.scan_status_var.set("Error. Press START SCAN again.")
            return

        # Successful read
        self.log_event(f"Arduino returned: {val}")
        self.last_color_var.set(f"Last read: {val}")

        # Update big display colors
        self.big_color_var.set(val)
        bg_map = {"GREEN":"#052418","RED":"#2A0B12","BLUE":"#071A2B","WHITE":"#E5E7EB","UNKNOWN":"#2A1B0B"}
        fg_map = {"GREEN":NEON_GREEN,"RED":NEON_RED,"BLUE":NEON_BLUE,"WHITE":"#111827","UNKNOWN":NEON_AMBER}
        self.big_color_lbl.config(bg=bg_map.get(val, CARD2), fg=fg_map.get(val, WHITE_TXT))

        # WHITE = immediate lock + hard shutdown meltdown
        if val == "WHITE":
            self.do_lock("WHITE detected")
            self.scan_status_var.set("WHITE detected — hard shutdown.")
            self.meltdown("WHITE DETECTED — HARD SHUTDOWN")
            return

        # GREEN = unlock
        if val == "GREEN":
            self.unknown_count = 0
            self.do_unlock("GREEN detected")
            self.scan_status_var.set("GREEN detected — unlocked.")
            popup_at("ACCESS", "GREEN DETECTED\nUNLOCKED", 30, 30, "#082A18", NEON_GREEN, ms=1100)
            return

        # RED = lock
        if val == "RED":
            self.unknown_count = 0
            self.do_lock("RED detected")
            self.scan_status_var.set("RED detected — locked.")
            popup_at("LOCK", "RED DETECTED\nLOCKED", 30, 30, "#2A0B12", "white", ms=1100)
            return

        # BLUE = police warning
        if val == "BLUE":
            self.unknown_count = 0
            self.do_lock("BLUE detected")
            self.scan_status_var.set("BLUE detected — police warning.")
            self.log_event("BLUE => police flash + siren")
            arduino_send("SIREN")
            police_flash_sequence(self.root, cycles=26, speed_ms=105)
            return

        # UNKNOWN = lock, count attempts, then meltdown at threshold
        if val == "UNKNOWN":
            self.do_lock("UNKNOWN detected")
            self.unknown_count += 1

            # First UNKNOWN: beep and ask to scan again
            if self.unknown_count < UNKNOWN_TRIGGER_COUNT:
                arduino_send("BEEP")
                self.log_event(f"UNKNOWN ({self.unknown_count}/{UNKNOWN_TRIGGER_COUNT})")
                self.scan_status_var.set(f"UNKNOWN ({self.unknown_count}/{UNKNOWN_TRIGGER_COUNT}) — scan again.")
                popup_at(
                    "⚠ UNKNOWN",
                    f"UNKNOWN ({self.unknown_count}/{UNKNOWN_TRIGGER_COUNT})\nScan again.",
                    30, 30, "#2A1B0B", NEON_AMBER, ms=1300
                )
                return

            # Second UNKNOWN: meltdown
            self.scan_status_var.set("UNKNOWN twice — meltdown.")
            self.meltdown("UNKNOWN DETECTED TWICE")
            return
